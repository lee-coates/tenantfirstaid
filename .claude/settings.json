{
  "env": {
    "UV_NO_CACHE": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.langchain.com)",
      "WebFetch(domain:reference.langchain.com)",
      "WebFetch(domain:ai.google.dev)",
      "WebFetch(domain:docs.digitalocean.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:docs.astral.sh)"
    ]
  },
  "enabledPlugins": {
    "astral@astral-sh": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "langsmith-skills@langsmith-skills": true,
    "legal@knowledge-work-plugins": true,
    "typescript-lsp@claude-plugins-official": true,
    "ultrareview@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "astral-sh": {
      "source": {
        "source": "github",
        "repo": "astral-sh/claude-code-plugins"
      }
    },
    "knowledge-work-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/knowledge-work-plugins"
      }
    },
    "langsmith-skills": {
      "source": {
        "source": "github",
        "repo": "langchain-ai/langsmith-skills"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "api.smith.langchain.com"
      ]
    }
  }
}
